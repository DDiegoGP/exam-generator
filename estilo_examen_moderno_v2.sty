% ============================================================================
% NUMERACIÓN DE PREGUNTAS (TikZ — escalable con pgfpages, sin blur)
%
%   \circled{N}        — cuadrado relleno claro (por defecto)
%   \circledCirculo{N} — círculo relleno (fondo color, número blanco)
%   \circledVacio{N}   — círculo vacío (solo borde)
%   \circledNumero{N}  — número en color, sin caja
%
% TikZ: pgfpages debe cargarse ANTES de este paquete para compatibilidad.
% ============================================================================
\newcommand*\circled[1]{%
    \tikz[baseline=(char.base)]{%
        \node[draw=primario, fill=primario!10,
              rectangle, rounded corners=1.5pt,
              inner sep=3pt, line width=0.8pt] (char)
              {\textbf{\textcolor{primario}{\small#1}}};%
    }%
}

\newcommand*\circledCirculo[1]{%
    \tikz[baseline=(char.base)]{%
        \node[draw=primario, fill=primario,
              circle, inner sep=3pt, line width=0.8pt] (char)
              {\textbf{\textcolor{white}{\small#1}}};%
    }%
}

\newcommand*\circledVacio[1]{%
    \tikz[baseline=(char.base)]{%
        \node[draw=primario, fill=white,
              circle, inner sep=3pt, line width=0.8pt] (char)
              {\textbf{\textcolor{primario}{\small#1}}};%
    }%
}

\newcommand*\circledNumero[1]{%
    \textbf{\textcolor{primario}{#1.}}%
}

% ============================================================================
% LISTAS Y PREGUNTAS
