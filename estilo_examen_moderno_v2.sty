\if@compacto
    \setlist[enumerate,1]{
        label=\protect\circled{\arabic*},
        leftmargin=*, itemsep=0.8em, topsep=0.5em,
        before={\color{texto}}, after={}
    }
\else
    \setlist[enumerate,1]{
        label=\protect\circled{\arabic*},
        leftmargin=*, itemsep=1.5em, topsep=1em,
        before={\color{texto}}, after={}
    }
\fi

% Segunda lista (opciones A/B/C/D)
\setlist[enumerate,2]{
    label=\textcolor{secundario}{\textbf{\alph*)}},
    leftmargin=2em, itemsep=0.5em, topsep=0.3em
}

% ============================================================================
% ESPACIO PARA RESPUESTAS DE DESARROLLO
%
%   \espaciorespuesta             → caja libre 6 cm
%   \espaciorespuesta[4cm]        → caja libre 4 cm
%   \espaciorespuesta[6cm]{lineas}→ caja con líneas horizontales 6 cm
%
% Segundo argumento opcional (G{libre}): «libre» o «lineas»
% ============================================================================
\NewDocumentCommand{\espaciorespuesta}{ O{6cm} G{libre} }{%
    \par\vspace{2mm}%
    \noindent%
    \def\@espr@mode{#2}%
    \def\@espr@libre{libre}%
    \ifx\@espr@mode\@espr@libre
        % --- Caja libre ---
        \fbox{%
            \begin{minipage}[t][#1][t]{\dimexpr\linewidth-2\fboxsep-2\fboxrule\relax}%
                \hspace{0pt}%
            \end{minipage}%
        }%
    \else
        % --- Caja con líneas horizontales (TikZ) ---
        \noindent\begin{tikzpicture}
            \draw[color=gray!60, line width=0.5pt]
                (0, 0) rectangle (\linewidth, #1);
            \pgfmathtruncatemacro{\esprnl}{(#1 - 0.4cm) / 0.65cm}
            \ifnum\esprnl>0
                \foreach \i in {1,...,\esprnl}{%
                    \draw[color=gray!35, line width=0.3pt]
                        (0.3cm, \i*0.65cm) -- (\linewidth-0.3cm, \i*0.65cm);%
                }%
            \fi
        \end{tikzpicture}%
    \fi
    \par\vspace{2mm}%
}

% ============================================================================
% SEPARADOR DE SECCIÓN
%   \seccionexamen{Título}{info opcional}   — el 2º arg puede ir vacío
% ============================================================================
\newcommand{\seccionexamen}[2]{%
    \vspace{4mm}%
    \noindent%
    {\Large\bfseries\color{primario}#1%
    \ifx&#2&%
    \else%
        \hfill{\normalsize\color{secundario}[#2]}%
    \fi}%
    \par\nobreak%
    {\color{primario}\rule{\linewidth}{1.5pt}}%
    \vspace{2mm}%
}

% ============================================================================
% INFO DE PREGUNTA (versión soluciones)
%   \infopregunta{bloque}{tema}{dificultad}
% ============================================================================
\newcommand{\infopregunta}[3]{%
    \par\vspace{0.5mm}%
    {\scriptsize\textcolor{gray!70}{%
        \textit{Bloque: #1 \textperiodcentered{} Tema: #2 \textperiodcentered{} Dif.: #3}%
    }}%
    \par\vspace{0.5mm}%
}

% ============================================================================
% CAJA DE CALIFICACIÓN
%   \notacalificacion[Título]{contenido}
%
% Ejemplos:
%   \notacalificacion[CALIFICACIÓN --- DESARROLLO]{%
%     Pregunta 1 (2 pts): \hrulefill \\[5mm]
%     Pregunta 2 (3 pts): \hrulefill \\[5mm]
%     \textbf{TOTAL:} \hrulefill / 5 pts%
%   }
%
%   \notacalificacion[NOTA FINAL]{%
%     Test: \hrulefill \quad + \quad Desarrollo: \hrulefill \\[6mm]
%     {\large\textbf{CALIFICACIÓN FINAL:}} \hrulefill / 10%
%   }
% ============================================================================
\newcommand{\notacalificacion}[2][CALIFICACIÓN]{%
    \vspace{6mm}%
    \begin{tcolorbox}[
        colback=primario!6,
        colframe=primario,
        coltitle=white,
        colbacktitle=primario,
        arc=2mm,
        boxrule=1.5pt,
        left=5mm, right=5mm, top=3mm, bottom=5mm,
        title={\small\bfseries #1}
    ]
        #2
    \end{tcolorbox}%
    \vspace{4mm}%
}

